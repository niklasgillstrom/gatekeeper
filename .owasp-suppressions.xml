<?xml version="1.0" encoding="UTF-8"?>
<!--
    OWASP Dependency-Check suppression file for gatekeeper.

    Suppress entries here ONLY when a CVE is a confirmed false positive in this
    project's threat model. Each suppression MUST include a notes field that
    explains (a) why the CVE does not apply, and (b) the date and reviewer who
    made the decision. Suppressions are reviewed annually as part of the DORA
    Article 9 ICT risk management cycle.

    Documentation: https://jeremylong.github.io/DependencyCheck/general/suppression.html
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        DOMPurify 3.3.2 bundled inside swagger-ui-5.32.2.jar (transitively
        via springdoc-openapi-starter-webmvc-ui:3.0.3, which is the latest
        stable release as of 2026-04-28).

        The vulnerability requires the application to configure DOMPurify
        with `ADD_TAGS` as a function (via `EXTRA_ELEMENT_HANDLING.tagCheck`)
        AND `FORBID_TAGS` simultaneously, in which case `FORBID_TAGS` is
        bypassed by short-circuit evaluation in `src/purify.ts:1117-1123`.

        Swagger UI's default configuration does not configure DOMPurify in
        this way; it is used to sanitise OpenAPI operation descriptions
        before rendering. This deployment uses Swagger UI with default
        settings (springdoc-openapi-starter-webmvc-ui at the production
        defaults documented in `application-nca.yaml`), so the vulnerable
        code path is not reachable.

        No upstream springdoc-openapi-starter-webmvc-ui release ships with
        a fixed DOMPurify yet — `versions:display-dependency-updates`
        confirms 3.0.3 is the latest stable. Suppression remains until
        upstream issues a fix and we bump the dependency.

        Reviewed annually as part of the DORA Article 9 ICT risk management
        cycle. Reviewed: 2026-04-28.
    -->
    <suppress>
        <notes><![CDATA[
            DOMPurify 3.3.2 inside swagger-ui (transitive via springdoc).
            ADD_TAGS-as-function + FORBID_TAGS interaction is the affected
            path; Swagger UI's default config does not exercise it.
            Reviewed: 2026-04-28.
        ]]></notes>
        <packageUrl regex="true">^pkg:javascript/DOMPurify@3\.3\.2$</packageUrl>
        <cve>CVE-2026-41238</cve>
        <cve>CVE-2026-41239</cve>
        <cve>CVE-2026-41240</cve>
        <vulnerabilityName regex="true">(?s).*ADD_TAGS.*FORBID_TAGS.*</vulnerabilityName>
    </suppress>

</suppressions>
